---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
---

<Layout 
  title="Nico Tatuaggi | Aftercare"
  description="Essential step-by-step guide for the perfect healing of your tattoo: washing, hydration, and restrictions."
  image="https://images.unsplash.com/photo-1608248593856-121f1981180b?auto=format&fit=crop&q=80&w=1200"
>
  <Nav />
  
  <main class="w-full min-h-screen pt-32 pb-24 px-6 max-w-4xl mx-auto">
    <div class="text-center mb-24">
        <h1 class="text-5xl md:text-6xl font-black text-white uppercase tracking-[0.2em] mb-4">Aftercare</h1>
        <p class="text-white/50 text-xs tracking-[0.4em] uppercase max-w-2xl mx-auto">Guide for the perfect healing of your tattoo</p>
    </div>

    <div class="space-y-6">
        {/* Step 1 */}
        <div class="accordion-item bg-[#080808]/80 border border-white/5 relative overflow-hidden group hover:border-tattoo-gold/30 transition-colors duration-500 cursor-pointer">
            <div class="accordion-header p-8 md:p-10 flex justify-between items-center relative z-10 w-full">
                <div class="flex items-center gap-6">
                    <div class="text-tattoo-gold opacity-80">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg>
                    </div>
                    <h2 class="text-xl md:text-2xl font-bold text-white uppercase tracking-[0.3em]">1. Washing</h2>
                </div>
                <div class="indicator text-tattoo-gold transition-transform duration-500">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                </div>
            </div>
            
            <div class="accordion-content h-0 overflow-hidden transition-all duration-500 ease-in-out opacity-0 px-8 md:px-10 pb-0">
                <div class="border-t border-white/10 pt-8 pb-10 flex flex-col md:flex-row gap-8 md:gap-12 items-start">
                    <div class="text-white/60 font-light leading-loose space-y-6 text-sm md:text-base flex-1">
                        <p>➤ Remove the film 2-3 hours after finishing the session. (If a dermal patch like Saniderm was applied, leave it for 3 to 5 days as instructed).</p>
                        <p>➤ Wash the area with lukewarm/cold water and neutral soap specific for tattoos or glycerin soap. Lather in your hands and gently rub the tattoo to remove excess ink, blood, or plasma.</p>
                        <p>➤ Dry with tissue paper (kitchen roll) using gentle dabbing motions, NEVER dragging. Let it air breathe for about 10-15 minutes.</p>
                    </div>
                    <div class="w-full md:w-2/5 aspect-video md:aspect-square lg:aspect-video overflow-hidden rounded-sm border border-white/5 relative group mt-4 md:mt-0 flex-shrink-0">
                        <img src="https://images.unsplash.com/photo-1584820927508-0125fb0ab691?auto=format&fit=crop&q=80&w=800" alt="Tattoo washing" class="w-full h-full object-cover grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700 group-hover:scale-105" />
                        <div class="absolute inset-0 bg-tattoo-gold/10 mix-blend-overlay group-hover:opacity-0 transition-opacity duration-500"></div>
                        <div class="absolute top-4 right-4 bg-black/80 px-3 py-1 text-[9px] tracking-widest text-tattoo-gold uppercase pointer-events-none">Neutral Soap</div>
                    </div>
                </div>
            </div>
        </div>

        {/* Step 2 */}
        <div class="accordion-item bg-[#080808]/80 border border-white/5 relative overflow-hidden group hover:border-tattoo-gold/30 transition-colors duration-500 cursor-pointer">
            <div class="accordion-header p-8 md:p-10 flex justify-between items-center relative z-10 w-full">
                <div class="flex items-center gap-6">
                    <div class="text-tattoo-gold opacity-80">
                         <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"/><path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/></svg>
                    </div>
                    <h2 class="text-xl md:text-2xl font-bold text-white uppercase tracking-[0.3em]">2. Hydration</h2>
                </div>
                <div class="indicator text-tattoo-gold transition-transform duration-500">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                </div>
            </div>
            
            <div class="accordion-content h-0 overflow-hidden transition-all duration-500 ease-in-out opacity-0 px-8 md:px-10 pb-0">
                <div class="border-t border-white/10 pt-8 pb-10 flex flex-col md:flex-row gap-8 md:gap-12 items-start">
                    <div class="w-full md:w-2/5 aspect-video md:aspect-square lg:aspect-[4/3] overflow-hidden rounded-sm border border-white/5 relative group mb-4 md:mb-0 md:order-1 flex-shrink-0">
                        <img src="https://images.unsplash.com/photo-1608248593856-121f1981180b?auto=format&fit=crop&q=80&w=800" alt="Tattoo hydration" class="w-full h-full object-cover grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700 group-hover:scale-105" />
                        <div class="absolute inset-0 bg-tattoo-gold/10 mix-blend-overlay group-hover:opacity-0 transition-opacity duration-500"></div>
                        <div class="absolute top-4 left-4 bg-black/80 px-3 py-1 text-[9px] tracking-widest text-tattoo-gold uppercase pointer-events-none">Thin Layer</div>
                    </div>
                    <div class="text-white/60 font-light leading-loose space-y-6 text-sm md:text-base flex-1 md:order-2">
                        <p>➤ From the 3rd day (or after removing the patch), start applying an EXTREMELY THIN layer of recommended tattoo cream (avoid Vaseline, scented creams, or alcohol-based lotions).</p>
                        <p>➤ Apply 2 to 3 times a day, only when the tattoo feels dry or tight. Over-moisturizing suffocates the tattoo, causes pimples, and leads to color loss.</p>
                        <p>➤ Continue moisturizing for at least 15 days.</p>
                    </div>
                </div>
            </div>
        </div>

        {/* Step 3 */}
        <div class="accordion-item bg-[#080808]/80 border border-white/5 relative overflow-hidden group hover:border-tattoo-gold/30 transition-colors duration-500 cursor-pointer">
            <div class="accordion-header p-8 md:p-10 flex justify-between items-center relative z-10 w-full">
                <div class="flex items-center gap-6">
                    <div class="text-tattoo-gold opacity-80">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" x2="19.07" y1="4.93" y2="19.07"/></svg>
                    </div>
                    <h2 class="text-xl md:text-2xl font-bold text-white uppercase tracking-[0.3em]">3. Restrictions</h2>
                </div>
                <div class="indicator text-tattoo-gold transition-transform duration-500">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                </div>
            </div>
            
            <div class="accordion-content h-0 overflow-hidden transition-all duration-500 ease-in-out opacity-0 px-8 md:px-10 pb-0">
                <div class="border-t border-white/10 pt-8 pb-10 flex flex-col md:flex-row gap-8 md:gap-12 items-start">
                    <ul class="text-white/60 font-light leading-loose space-y-4 text-sm md:text-base list-none flex-1">
                        <li class="pl-4 relative before:content-[''] before:absolute before:left-0 before:top-3 before:w-1.5 before:h-1.5 before:bg-tattoo-gold before:rounded-full">NO scratching, rubbing, or peeling off the scabs or flaking skin.</li>
                        <li class="pl-4 relative before:content-[''] before:absolute before:left-0 before:top-3 before:w-1.5 before:h-1.5 before:bg-tattoo-gold before:rounded-full">NO submerging in pools, sea, lakes, or bathtubs for 15-20 days (quick showers only).</li>
                        <li class="pl-4 relative before:content-[''] before:absolute before:left-0 before:top-3 before:w-1.5 before:h-1.5 before:bg-tattoo-gold before:rounded-full">NO direct sun exposure or tanning beds for 1 month. Afterwards, ALWAYS use total sunblock.</li>
                        <li class="pl-4 relative before:content-[''] before:absolute before:left-0 before:top-3 before:w-1.5 before:h-1.5 before:bg-tattoo-gold before:rounded-full">NO intense physical exercise or activities causing excessive sweating in the area during the first week.</li>
                        <li class="pl-4 relative before:content-[''] before:absolute before:left-0 before:top-3 before:w-1.5 before:h-1.5 before:bg-tattoo-gold before:rounded-full">Avoid tight clothing that constantly rubs against the fresh tattoo.</li>
                    </ul>
                    <div class="w-full md:w-2/5 aspect-video md:aspect-[4/5] overflow-hidden rounded-sm border border-white/5 relative group mt-4 md:mt-0 flex-shrink-0">
                        <img src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&q=80&w=800" alt="Avoid sun and sea" class="w-full h-full object-cover grayscale opacity-50 group-hover:grayscale-0 group-hover:opacity-90 transition-all duration-700 group-hover:scale-105" />
                        <div class="absolute inset-0 bg-red-900/20 mix-blend-overlay group-hover:opacity-0 transition-opacity duration-500"></div>
                        <div class="absolute top-4 right-4 bg-black/80 px-3 py-1 text-[9px] tracking-widest text-[#ff4444] uppercase pointer-events-none flex items-center gap-2">
                             <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                            Avoid
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="mt-20 text-center">
        <p class="text-white/30 text-xs tracking-[0.4em] uppercase">If you have any doubts or anomalies, contact immediately via WhatsApp.</p>
    </div>
  </main>
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const accordionItems = document.querySelectorAll('.accordion-item');

        accordionItems.forEach(item => {
            const header = item.querySelector('.accordion-header');
            const content = item.querySelector('.accordion-content');
            const indicator = item.querySelector('.indicator');

            header.addEventListener('click', () => {
                const isOpen = item.classList.contains('active');

                // Close all
                accordionItems.forEach(otherItem => {
                    otherItem.classList.remove('active');
                    const otherContent = otherItem.querySelector('.accordion-content');
                    const otherIndicator = otherItem.querySelector('.indicator');
                    otherContent.style.height = '0px';
                    otherContent.classList.remove('opacity-100');
                    otherIndicator.style.transform = 'rotate(0deg)';
                    otherItem.classList.remove('border-tattoo-gold/50');
                });

                // If it wasn't open, open it
                if (!isOpen) {
                    item.classList.add('active');
                    content.style.height = content.scrollHeight + 'px';
                    content.classList.add('opacity-100');
                    indicator.style.transform = 'rotate(180deg)';
                    item.classList.add('border-tattoo-gold/50');
                }
            });
        });
        
        // Open first by default
        if(accordionItems.length > 0) {
             accordionItems[0].querySelector('.accordion-header').click();
        }
    });
</script>

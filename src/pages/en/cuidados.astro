---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';

const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL || 'http://localhost:8055';
const DIRECTUS_TOKEN = import.meta.env.DIRECTUS_API_TOKEN || '';

const getAssetData = (obj) => {
    if (!obj) return null;
    if (typeof obj === 'string') return { id: obj, mime: null };
    if (obj.directus_files_id) return { id: obj.directus_files_id.id || obj.directus_files_id, mime: obj.directus_files_id.type };
    return { id: obj.id, mime: obj.type };
};

const getAssetUrl = (obj, params = '') => {
    const data = getAssetData(obj);
    if (!data || !data.id) return null;
    return `${DIRECTUS_URL}/assets/${data.id}${params ? '?' + params : ''}`;
};

const fetchDirectus = async () => {
  try {
    const res = await fetch(`${DIRECTUS_URL}/items/care?fields=*.*`, {
      headers: DIRECTUS_TOKEN ? { Authorization: `Bearer ${DIRECTUS_TOKEN}` } : {}
    });
    if (!res.ok) return null;
    const json = await res.json();
    return json.data;
  } catch (e) {
    return null;
  }
};

let careData = null;
try {
  careData = await fetchDirectus();
} catch (e) {
  console.error("Error fetching Care data from Directus", e);
}

// Fallbacks (Wait for Directus to support i18n, manually fallback English if CMS empty or use CMS payload since Nico writes it)
const pageTitle = careData?.title || "Aftercare";
const pageSubtitle = careData?.subtitle || "Guide for the perfect healing of your tattoo";
const steps = careData?.steps && careData.steps.length > 0 ? careData.steps : [
    {
        title: "1. Washing",
        icon: "wash",
        description: "➤ Remove the film 2-3 hours after finishing the session.\n➤ Wash the area with lukewarm/cold water and neutral soap.\n➤ Dry with tissue paper.",
        alertText: "Neutral Soap",
        image: { url: "https://images.unsplash.com/photo-1584820927508-0125fb0ab691?auto=format&fit=crop&q=80&w=800" }
    },
    {
        title: "2. Hydration",
        icon: "hydrate",
        description: "➤ From the 3rd day, start applying an EXTREMELY THIN layer of cream.\n➤ Apply 2 to 3 times a day.\n➤ Continue moisturizing for at least 15 days.",
        alertText: "Thin Layer",
        image: { url: "https://images.unsplash.com/photo-1608248593856-121f1981180b?auto=format&fit=crop&q=80&w=800" }
    },
    {
        title: "3. Restrictions",
        icon: "avoid",
        description: "➤ NO scratching, rubbing or peeling off the scabs.\n➤ NO submerging in pools or sea.\n➤ NO direct sun exposure.",
        alertText: "Avoid",
        image: { url: "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&q=80&w=800" }
    }
];

const renderIcon = (iconType) => {
    switch(iconType) {
        case 'hydrate':
            return `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"/><path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/></svg>`;
        case 'avoid':
            return `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" x2="19.07" y1="4.93" y2="19.07"/></svg>`;
        case 'wash':
        default:
            return `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg>`;
    }
};
---

<Layout 
  title="Nico Tatuaggi | Aftercare"
  description="Essential step-by-step guide for the perfect healing of your tattoo: washing, hydration, and restrictions."
  image="https://images.unsplash.com/photo-1608248593856-121f1981180b?auto=format&fit=crop&q=80&w=1200"
>
  <Nav />
  
  <main class="w-full min-h-screen pt-32 pb-24 px-6 max-w-4xl mx-auto">
    <div class="text-center mb-24">
        <h1 class="text-5xl md:text-6xl font-black text-white uppercase tracking-[0.2em] mb-4">{pageTitle}</h1>
        <p class="text-white/50 text-xs tracking-[0.4em] uppercase max-w-2xl mx-auto">{pageSubtitle}</p>
    </div>

    <div class="space-y-6">
        {steps.map((step, index) => {
            const imageUrl = step.image ? getAssetUrl(step.image, 'width=800&quality=80&format=webp') : "https://images.unsplash.com/photo-1584820927508-0125fb0ab691?auto=format&fit=crop&q=80&w=800";
            const paragraphs = step.description ? step.description.split('\n').filter(p => p.trim() !== '') : [];

            return (
                <div class="accordion-item bg-[#080808]/80 border border-white/5 relative overflow-hidden group hover:border-tattoo-gold/30 transition-colors duration-500 cursor-pointer">
                    <div class="accordion-header p-8 md:p-10 flex justify-between items-center relative z-10 w-full">
                        <div class="flex items-center gap-6">
                            <div class="text-tattoo-gold opacity-80" set:html={renderIcon(step.icon)} />
                            <h2 class="text-xl md:text-2xl font-bold text-white uppercase tracking-[0.3em]">{step.title}</h2>
                        </div>
                        <div class="indicator text-tattoo-gold transition-transform duration-500">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                        </div>
                    </div>
                    
                    <div class="accordion-content h-0 overflow-hidden transition-all duration-500 ease-in-out opacity-0 px-8 md:px-10 pb-0">
                        <div class="border-t border-white/10 pt-8 pb-10 flex flex-col md:flex-row gap-8 md:gap-12 items-start">
                            <div class={`text-white/60 font-light leading-loose space-y-6 text-sm md:text-base flex-1 ${index % 2 !== 0 ? 'md:order-2' : ''}`}>
                                {paragraphs.map(p => <p>{p}</p>)}
                            </div>
                            <div class={`w-full md:w-2/5 aspect-video overflow-hidden rounded-sm border border-white/5 relative group mt-4 md:mt-0 flex-shrink-0 ${index % 2 !== 0 ? 'md:order-1 mb-4 md:mb-0' : ''}`}>
                                <img src={imageUrl} alt={step.title} class="w-full h-full object-cover grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700 group-hover:scale-105" />
                                <div class={`absolute inset-0 mix-blend-overlay group-hover:opacity-0 transition-opacity duration-500 ${step.icon === 'avoid' ? 'bg-red-900/20' : 'bg-tattoo-gold/10'}`}></div>
                                {step.alertText && (
                                    <div class={`absolute ${index % 2 !== 0 ? 'top-4 left-4' : 'top-4 right-4'} bg-black/80 px-3 py-1 text-[9px] tracking-widest uppercase pointer-events-none flex items-center gap-2 ${step.icon === 'avoid' ? 'text-[#ff4444]' : 'text-tattoo-gold'}`}>
                                        {step.icon === 'avoid' && <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>}
                                        {step.alertText}
                                    </div>
                                )}
                            </div>
                        </div>
                    </div>
                </div>
            );
        })}
    </div>
    
    <div class="mt-20 text-center">
        <p class="text-white/30 text-xs tracking-[0.4em] uppercase">If you have any doubts or anomalies, contact immediately via WhatsApp.</p>
    </div>
  </main>
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const accordionItems = document.querySelectorAll('.accordion-item');

        accordionItems.forEach(item => {
            const header = item.querySelector('.accordion-header');
            const content = item.querySelector('.accordion-content');
            const indicator = item.querySelector('.indicator');

            header.addEventListener('click', () => {
                const isOpen = item.classList.contains('active');

                // Close all
                accordionItems.forEach(otherItem => {
                    otherItem.classList.remove('active');
                    const otherContent = otherItem.querySelector('.accordion-content');
                    const otherIndicator = otherItem.querySelector('.indicator');
                    otherContent.style.height = '0px';
                    otherContent.classList.remove('opacity-100');
                    otherIndicator.style.transform = 'rotate(0deg)';
                    otherItem.classList.remove('border-tattoo-gold/50');
                });

                // If it wasn't open, open it
                if (!isOpen) {
                    item.classList.add('active');
                    content.style.height = content.scrollHeight + 'px';
                    content.classList.add('opacity-100');
                    indicator.style.transform = 'rotate(180deg)';
                    item.classList.add('border-tattoo-gold/50');
                }
            });
        });
        
        // Open first by default
        if(accordionItems.length > 0) {
             accordionItems[0].querySelector('.accordion-header').click();
        }
    });
</script>

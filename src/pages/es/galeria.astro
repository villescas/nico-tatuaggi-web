---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Tattoo from '../../components/Tattoo.astro';

const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL || 'http://200.58.127.97:8055';
const DIRECTUS_TOKEN = import.meta.env.DIRECTUS_API_TOKEN || '';

const getAssetData = (obj) => {
    if (!obj) return null;
    if (typeof obj === 'string') return { id: obj, mime: null };
    if (obj.directus_files_id) return { id: obj.directus_files_id.id || obj.directus_files_id, mime: obj.directus_files_id.type };
    return { id: obj.id, mime: obj.type };
};

const getAssetUrl = (obj, params = '') => {
    const data = getAssetData(obj);
    if (!data || !data.id) return null;
    return `${DIRECTUS_URL}/assets/${data.id}${params ? '?' + params : ''}`;
};

const fetchDirectus = async (endpoint, query = '?fields=*.*') => {
  try {
    const res = await fetch(`${DIRECTUS_URL}/items/${endpoint}${query}`, {
      headers: DIRECTUS_TOKEN ? { Authorization: `Bearer ${DIRECTUS_TOKEN}` } : {}
    });
    if (!res.ok) return null;
    const json = await res.json();
    return json.data;
  } catch (e) {
    return null;
  }
};

let tatuajes = [];

try {
  const rawTattoos = await fetchDirectus('tatuajes', '?limit=100&fields=*.*');
  if (rawTattoos) {
      tatuajes = rawTattoos.map(t => ({
          titulo: t.titulo,
          sede: t.sede,
          imagenUrl: t.imagen_portada ? getAssetUrl(t.imagen_portada, 'width=600&quality=80&format=webp') : null,
          linkVideo: t.link_video,
          esVideo: t.es_video
      }));
  }
} catch (e) {
    console.error("Error fetching from Directus", e);
}

// Fallback Data if Directus is empty
if (tatuajes.length === 0) {
    tatuajes = [
        { titulo: "León Realista", sede: "Londres", imagenUrl: "https://images.unsplash.com/photo-1598371839696-5c5bb00bdc28?auto=format&fit=crop&q=80&w=800", esVideo: false },
        { titulo: "Rostro Mujer", sede: "Buenos Aires", imagenUrl: "https://images.unsplash.com/photo-1611501275019-9b5cda994e8d?auto=format&fit=crop&q=80&w=800", esVideo: false },
        { titulo: "Reloj y Rosas", sede: "Londres", imagenUrl: "https://images.unsplash.com/photo-1590246814883-57832efa2629?auto=format&fit=crop&q=80&w=800", esVideo: false },
        { titulo: "Tigre", sede: "Buenos Aires", imagenUrl: "https://images.unsplash.com/photo-1562962230-16e4623d36e6?auto=format&fit=crop&q=80&w=800", esVideo: false },
        { titulo: "Dragón Japonés", sede: "Londres", imagenUrl: "https://images.unsplash.com/photo-1605369683796-01d81de54130?auto=format&fit=crop&q=80&w=800", esVideo: false },
        { titulo: "Lobo Cover Up", sede: "Buenos Aires", imagenUrl: "https://images.unsplash.com/photo-1550684376-efcbd6e3f031?auto=format&fit=crop&q=80&w=800", esVideo: false },
        { titulo: "Cráneo", sede: "Londres", imagenUrl: "https://images.unsplash.com/photo-1621252178972-2aa54ef84c33?auto=format&fit=crop&q=80&w=800", esVideo: false },
        { titulo: "Microrealismo Ojo", sede: "Buenos Aires", imagenUrl: "https://images.unsplash.com/photo-1565347878385-d7a8d78fe975?auto=format&fit=crop&q=80&w=800", esVideo: false },
        { titulo: "Flores Cover Up", sede: "Londres", imagenUrl: "https://images.unsplash.com/photo-1611501275019-9b5cda994e8d?auto=format&fit=crop&q=80&w=800", esVideo: false }
    ];
}
---

<Layout 
  title="Nico Tatuaggi | Portfolio Galería"
  description="Explora la galería completa de trabajos de realismo, color y cover-up de Nico Tatuaggi."
  image={tatuajes.length > 0 && tatuajes[0].imagenUrl ? tatuajes[0].imagenUrl : 'https://images.unsplash.com/photo-1598371839696-5c5bb00bdc28?auto=format&fit=crop&q=80&w=1200'}
>
  <Nav />
  
  <main class="w-full min-h-screen pt-32 pb-24 px-6 max-w-7xl mx-auto">
    <div class="text-center mb-16">
        <h1 class="text-5xl md:text-6xl font-black text-white uppercase tracking-tighter mb-4">Portfolio</h1>
        <p class="text-tattoo-gold text-sm tracking-[0.3em] uppercase max-w-2xl mx-auto">Explora la galería completa de trabajos</p>
    </div>

    {/* Filtros visuales usando Alpine o simple CSS/JS vanilla */}
    <div class="flex flex-wrap justify-center gap-4 mb-16 filter-buttons">
        <button class="px-6 py-2 border border-tattoo-gold text-tattoo-gold hover:bg-tattoo-gold hover:text-black transition-colors text-xs tracking-widest uppercase active-filter" data-filter="all">Todos</button>
        <button class="px-6 py-2 border border-tattoo-gold/30 text-tattoo-silver hover:border-tattoo-gold hover:text-tattoo-gold transition-colors text-xs tracking-widest uppercase" data-filter="Buenos Aires">Buenos Aires</button>
        <button class="px-6 py-2 border border-tattoo-gold/30 text-tattoo-silver hover:border-tattoo-gold hover:text-tattoo-gold transition-colors text-xs tracking-widest uppercase" data-filter="Londres">Londres</button>
    </div>

    <div class="columns-1 md:columns-2 lg:columns-3 gap-6 space-y-6 portfolio-grid">
      {tatuajes.map((tatuaje) => (
        <div class={`tattoo-item transition-all duration-500`} data-sede={tatuaje.sede}>
            <Tattoo 
            titulo={tatuaje.titulo} 
            sede={tatuaje.sede} 
            imagenUrl={tatuaje.imagenUrl} 
            linkVideo={tatuaje.linkVideo}
            esVideo={tatuaje.esVideo}
            />
        </div>
      ))}
    </div>
  </main>
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const buttons = document.querySelectorAll('.filter-buttons button');
        const items = document.querySelectorAll('.tattoo-item');

        buttons.forEach(button => {
            button.addEventListener('click', () => {
                // Update active button styling
                buttons.forEach(btn => {
                    btn.classList.remove('border-tattoo-gold', 'text-tattoo-gold', 'bg-tattoo-gold', 'text-black', 'active-filter');
                    btn.classList.add('border-tattoo-gold/30', 'text-tattoo-silver');
                    // Reset to unselected base state, then we'll apply selected state below
                });
                
                button.classList.remove('border-tattoo-gold/30', 'text-tattoo-silver');
                button.classList.add('border-tattoo-gold', 'text-tattoo-gold', 'bg-tattoo-gold', 'text-black', 'active-filter'); // In a real scenario you might just want it gold border/text until hover, but this shows active state

                const filterValue = button.getAttribute('data-filter');

                items.forEach(item => {
                    if (filterValue === 'all' || item.getAttribute('data-sede') === filterValue) {
                        item.style.display = 'block';
                        // Small timeout to allow display:block to apply before animating opacity
                        setTimeout(() => {
                            item.style.opacity = '1';
                            item.style.transform = 'scale(1)';
                        }, 50);
                    } else {
                        item.style.opacity = '0';
                        item.style.transform = 'scale(0.95)';
                        setTimeout(() => {
                             item.style.display = 'none';
                        }, 300); // Matches transition duration
                    }
                });
            });
        });
    });
</script>

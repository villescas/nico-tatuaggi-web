---
const { name, bio, imageUrl, whatsapp, instagram } = Astro.props;
---

<div class="w-full max-w-6xl mx-auto px-6 py-20 flex flex-col md:flex-row items-center gap-12 border-t border-tattoo-gold/20">
  
  <div class="w-full md:w-1/2 flex justify-center">
    <div class="relative w-72 h-72 md:w-96 md:h-96">
      <div class="absolute inset-0 border border-tattoo-gold/30 rotate-3 transition-transform duration-500 hover:rotate-6"></div>
      <div class="absolute inset-0 border border-tattoo-gold/30 -rotate-3 transition-transform duration-500 hover:-rotate-6"></div>
      
      {imageUrl ? (
        <img 
          src={imageUrl} 
          alt={name} 
          class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 relative z-10"
        />
      ) : (
        <div class="w-full h-full bg-[#111] border border-tattoo-silver/20 flex items-center justify-center relative z-10 text-tattoo-silver/50 text-xs tracking-widest">
          FOTO DE PERFIL
        </div>
      )}
    </div>
  </div>

  <div class="w-full md:w-1/2 flex flex-col items-center md:items-start text-center md:text-left">
    <h2 class="text-4xl md:text-5xl font-bold text-tattoo-silver uppercase tracking-widest mb-6">
      {name || 'El Artista'}
    </h2>
    
    <div class="w-12 h-[2px] bg-tattoo-gold mb-6"></div>
    
    <p class="text-white/70 font-light leading-relaxed tracking-wide mb-10 text-sm md:text-base">
      {bio || 'La biografía del artista aparecerá aquí una vez cargada en el panel de control.'}
    </p>

    <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
      {whatsapp && (
        <a href={`https://wa.me/${String(whatsapp).replace(/[^0-9]/g, '')}`} target="_blank" class="px-8 py-4 bg-tattoo-gold text-black font-bold uppercase tracking-[0.2em] text-xs hover:bg-white transition-colors flex items-center justify-center gap-2">
          <span>WhatsApp</span>
        </a>
      )}
      
      {instagram && (
        <a href={instagram} target="_blank" class="px-8 py-4 bg-transparent border border-tattoo-gold text-tattoo-gold font-bold uppercase tracking-[0.2em] text-xs hover:bg-tattoo-gold hover:text-black transition-colors flex items-center justify-center gap-2">
          <span>Instagram</span>
        </a>
      )}
    </div>
  </div>
</div>

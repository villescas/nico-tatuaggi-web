---
// src/components/Nav.astro

// Extraemos el lenguaje de la URL actual
const { pathname } = Astro.url;
const currentLang = pathname.startsWith('/en') ? 'en' : 'es';

// Función para generar las URLs cambiando solo el idioma
const getSwitcherUrl = (targetLang) => {
  // Si estamos en /es/galeria y cambiamos a /en, la URL será /en/galeria
  // Si la ruta no tiene idioma explícito (ej: /), redirigimos a /en o /es
  if (pathname === '/') return `/${targetLang}`;
  
  const segments = pathname.split('/').filter(Boolean);
  if (segments[0] === 'es' || segments[0] === 'en') {
    segments[0] = targetLang;
  } else {
    segments.unshift(targetLang);
  }
  return `/${segments.join('/')}`;
};

// Rutas dinámicas según el idioma actual
const langPrefix = `/${currentLang}`;
---

<nav class="absolute top-0 w-full z-50 px-4 md:px-8 py-6 md:py-8 flex items-center justify-between bg-transparent">
  {/* Left: Logo */}
  <div class="flex-1 flex justify-start">
    <a href={langPrefix} class="text-tattoo-gold font-bold text-lg md:text-xl tracking-[0.3em] md:tracking-[0.4em] uppercase whitespace-nowrap">
      Nico Tatuaggi
    </a>
  </div>
  
  {/* Center: Links */}
  <div class="hidden md:flex flex-none justify-center gap-10 nav-links">
    <a href={`${langPrefix}/galeria`} class="nav-item text-white/70 hover:text-tattoo-gold transition-colors text-xs tracking-[0.4em] uppercase py-2 border-b border-transparent">Portfolio</a>
    <a href={`${langPrefix}/sobre-nico`} class="nav-item text-white/70 hover:text-tattoo-gold transition-colors text-xs tracking-[0.4em] uppercase py-2 border-b border-transparent">El Artista</a>
    <a href={`${langPrefix}/cuidados`} class="nav-item text-white/70 hover:text-tattoo-gold transition-colors text-xs tracking-[0.4em] uppercase py-2 border-b border-transparent">Cuidados</a>
    <a href={`${langPrefix}/faq`} class="nav-item text-white/70 hover:text-tattoo-gold transition-colors text-xs tracking-[0.4em] uppercase py-2 border-b border-transparent">FAQ</a>
  </div>
  
  {/* Right: Language Switcher & Mobile Menu */}
  <div class="flex-1 flex justify-end items-center gap-4 md:gap-6">
    <div class="flex items-center gap-2 md:gap-3 text-[10px] tracking-[0.3em] uppercase font-bold">
      {/* Lucide Globe Icon SVG */}
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/50"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>
      <a href={getSwitcherUrl('es')} class={`transition-colors ${currentLang === 'es' ? 'text-white' : 'text-white/30 hover:text-white'}`}>
        ES
      </a>
      <span class="text-white/20">|</span>
      <a href={getSwitcherUrl('en')} class={`transition-colors ${currentLang === 'en' ? 'text-white' : 'text-white/30 hover:text-white'}`}>
        EN
      </a>
    </div>

    {/* Mobile Menu Button */}
    <button id="mobile-menu-btn" class="md:hidden text-tattoo-gold z-[60] relative" aria-label="Toggle Menu">
      <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 opacity-100 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 absolute inset-0 opacity-0 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
  
  {/* Mobile Menu Overlay */}
  <div id="mobile-menu" class="fixed inset-0 bg-[#050505]/98 backdrop-blur-xl z-50 flex flex-col items-center justify-center opacity-0 pointer-events-none transition-all duration-500 scale-95 md:hidden">
    <div class="flex flex-col items-center gap-10 w-full px-6">
      <a href={`${langPrefix}/galeria`} class="nav-item mobile-nav-item text-white/70 hover:text-tattoo-gold transition-colors text-sm tracking-[0.4em] uppercase py-4 border-b border-white/5 w-full text-center">Portfolio</a>
      <a href={`${langPrefix}/sobre-nico`} class="nav-item mobile-nav-item text-white/70 hover:text-tattoo-gold transition-colors text-sm tracking-[0.4em] uppercase py-4 border-b border-white/5 w-full text-center">El Artista</a>
      <a href={`${langPrefix}/cuidados`} class="nav-item mobile-nav-item text-white/70 hover:text-tattoo-gold transition-colors text-sm tracking-[0.4em] uppercase py-4 border-b border-white/5 w-full text-center">Cuidados</a>
      <a href={`${langPrefix}/faq`} class="nav-item mobile-nav-item text-white/70 hover:text-tattoo-gold transition-colors text-sm tracking-[0.4em] uppercase py-4 border-b border-white/5 w-full text-center">FAQ</a>
    </div>
  </div>
</nav>

<script>
  // Script para marcar el link activo
  document.addEventListener('DOMContentLoaded', () => {
    const currentPath = window.location.pathname;
    const navLinks = document.querySelectorAll('.nav-item');
    
    navLinks.forEach(link => {
      const href = link.getAttribute('href');
      // Coincidencia exacta o si estamos en /es/galeria y el link es /es/galeria
      if (currentPath === href || (href !== '/' && href !== '/es' && href !== '/en' && currentPath.startsWith(href))) {
        link.classList.remove('text-white/70', 'border-transparent');
        link.classList.add('text-tattoo-gold', 'border-tattoo-gold', 'font-bold');
      }
    });

    // Mobile Menu Toggle Logic
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');
    let isMenuOpen = false;

    if (mobileBtn && mobileMenu && iconOpen && iconClose) {
      mobileBtn.addEventListener('click', () => {
        isMenuOpen = !isMenuOpen;
        
        if (isMenuOpen) {
          // Open menu
          mobileMenu.classList.remove('opacity-0', 'pointer-events-none', 'scale-95');
          mobileMenu.classList.add('opacity-100', 'scale-100');
          iconOpen.classList.replace('opacity-100', 'opacity-0');
          iconClose.classList.replace('opacity-0', 'opacity-100');
          document.body.style.overflow = 'hidden'; // Prevent scrolling background
        } else {
          // Close menu
          mobileMenu.classList.remove('opacity-100', 'scale-100');
          mobileMenu.classList.add('opacity-0', 'pointer-events-none', 'scale-95');
          iconOpen.classList.replace('opacity-0', 'opacity-100');
          iconClose.classList.replace('opacity-100', 'opacity-0');
          document.body.style.overflow = '';
        }
      });
    }
  });
</script>
